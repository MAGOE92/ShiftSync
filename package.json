{
  "name": "shiftsync-pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:all": "vitest run && npm run test:e2e",
    "icons": "node scripts/gen-icons.cjs",
    "test:e2e": "npx esbuild tests/entry.jsx --bundle --jsx=automatic --format=iife --loader:.jsx=jsx --loader:.js=jsx --log-level=error --outfile=./bundle.tmp.js && cross-env BUNDLE=./bundle.tmp.js node tests/e2e.test.cjs",
    "test:e2e:unix": "npx esbuild tests/entry.jsx --bundle --jsx=automatic --format=iife --loader:.jsx=jsx --loader:.js=jsx --log-level=error --outfile=/tmp/bundle.js && node tests/e2e.test.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "supabase": "^2.106.0",
    "vite": "^5.4.19",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.9",
    "workbox-window": "^7.4.1"
  }
}
