# ────────────────────────────────────────────────────────────────
# ShiftSync Pro · Umgebungsvariablen
# Kopiere diese Datei zu .env.local und fülle sie aus.
# Niemals .env.local committen!
# ────────────────────────────────────────────────────────────────

# ── Storage-Backend ──────────────────────────────────────────────
# "local" (window.storage/localStorage, kein Backend nötig)
# "supabase" (zentrale Cloud-DB über das Edge-Function-Gateway "api")
VITE_STORAGE=local

# ── Supabase (nur bei VITE_STORAGE=supabase) ─────────────────────
# Settings → API. Der Client spricht NUR mit der Edge-Function "api",
# nie direkt mit den Tabellen (RLS ist komplett gesperrt).
VITE_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
# "Publishable key" (sb_publishable_…) ODER Legacy-anon-Key (eyJ…).
# Darf öffentlich sein — gibt ohne gültiges Gateway-Token keinen Zugriff.
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ── Stripe ──────────────────────────────────────────────────────
# Auf "true" setzen um Upgrade-Buttons in der UI anzuzeigen
VITE_STRIPE_ENABLED=false

# ────────────────────────────────────────────────────────────────
# Server-seitige Secrets — NICHT hier, sondern in Supabase setzen via:
#   npx supabase secrets set --project-ref <ref> KEY=value
# ────────────────────────────────────────────────────────────────
# SESSION_SECRET   = langer Zufallsstring (signiert die Login-Tokens, HMAC-SHA256)
# SUPER_ADMIN_PW   = Passwort für den Anbieter-Login (Code ADMIN / superadmin)
# (SUPABASE_URL und SUPABASE_SERVICE_ROLE_KEY injiziert Supabase automatisch)
#
# Stripe (Phase 3, noch nicht aktiv):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_IDS={"starter":"price_xxx","pro":"price_yyy","business":"price_zzz"}
