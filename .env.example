# ────────────────────────────────────────────────────────────────
# ShiftSync Pro · Umgebungsvariablen
# Kopiere diese Datei zu .env.local und fülle sie aus.
# Niemals .env.local committen!
# ────────────────────────────────────────────────────────────────

# ── Storage-Backend ──────────────────────────────────────────────
# "local" (window.storage/localStorage) oder "supabase"
VITE_STORAGE=local

# ── Supabase ────────────────────────────────────────────────────
# Nur nötig wenn VITE_STORAGE=supabase
VITE_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Stripe ──────────────────────────────────────────────────────
# Auf "true" setzen um Upgrade-Buttons in der UI anzuzeigen
VITE_STRIPE_ENABLED=false

# ── Supabase Edge Functions Secrets (nicht in .env, in Supabase Dashboard) ──
# SUPER_ADMIN_PW=geheim
# JWT_SECRET=min-32-zeichen-zufaelliger-string
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_IDS={"starter":"price_xxx","pro":"price_yyy","business":"price_zzz"}
# APP_URL=https://shiftsync.app
